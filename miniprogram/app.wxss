/* 全局样式 - 现代简约风格 */
page {
  background-color: #FAFAFA;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  line-height: 1.6;
}

/* 主色调 - 柔和配色 */
.primary-color {
  color: #5B8FF9;
}

.primary-bg {
  background-color: #5B8FF9;
}

/* 辅助色 */
.success-color {
  color: #52C41A;
}

.warning-color {
  color: #FAAD14;
}

.error-color {
  color: #F5222D;
}

/* 文字颜色 */
.text-primary {
  color: #262626;
}

.text-secondary {
  color: #8C8C8C;
}

.text-hint {
  color: #BFBFBF;
}

/* 背景色 */
.bg-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: #5B8FF9;
  color: white;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: white;
  color: #5B8FF9;
  height: 88rpx;
  border-radius: 16rpx;
  border: 2rpx solid #5B8FF9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background-color: #F5F5F5;
}

.btn-text {
  color: #5B8FF9;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 400;
  background-color: transparent;
  border: none;
}

/* 输入框样式 */
.input {
  height: 88rpx;
  border-radius: 12rpx;
  border: 2rpx solid #F0F0F0;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #262626;
  background-color: #FAFAFA;
}

.input:focus {
  border-color: #5B8FF9;
  background-color: #FFFFFF;
}

/* 列表样式 */
.list-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 32rpx 0;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #BFBFBF;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 标题样式 */
.title-large {
  font-size: 40rpx;
  font-weight: 600;
  color: #262626;
  line-height: 56rpx;
}

.title-medium {
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
  line-height: 48rpx;
}

/* 正文样式 */
.text-body {
  font-size: 32rpx;
  color: #262626;
  line-height: 48rpx;
}

.text-small {
  font-size: 28rpx;
  color: #8C8C8C;
  line-height: 40rpx;
}

.text-xs {
  font-size: 24rpx;
  color: #BFBFBF;
  line-height: 32rpx;
}

/* 间距 */
.mt-8 {
  margin-top: 16rpx;
}

.mt-16 {
  margin-top: 32rpx;
}

.mb-8 {
  margin-bottom: 16rpx;
}

.mb-16 {
  margin-bottom: 32rpx;
}

.p-16 {
  padding: 32rpx;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}