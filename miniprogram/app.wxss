/* 全局样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 主色调 */
.primary-color {
  color: #3478F6;
}

.primary-bg {
  background-color: #3478F6;
}

/* 辅助色 */
.success-color {
  color: #4CAF50;
}

.warning-color {
  color: #FF9800;
}

.error-color {
  color: #F44336;
}

/* 文字颜色 */
.text-primary {
  color: #212121;
}

.text-secondary {
  color: #757575;
}

.text-hint {
  color: #9E9E9E;
}

/* 背景色 */
.bg-card {
  background-color: #FFFFFF;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 16px;
  margin-bottom: 12px;
}

/* 按钮样式 */
.btn-primary {
  background-color: #3478F6;
  color: white;
  height: 44px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 400;
}

.btn-secondary {
  background-color: white;
  color: #3478F6;
  height: 44px;
  border-radius: 8px;
  border: 1px solid #3478F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 400;
}

.btn-text {
  color: #3478F6;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 400;
}

/* 输入框样式 */
.input {
  height: 44px;
  border-radius: 8px;
  border: 1px solid #E0E0E0;
  padding: 0 16px;
  font-size: 16px;
  color: #212121;
}

.input:focus {
  border-color: #3478F6;
}

/* 列表样式 */
.list-item {
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  border-bottom: 1px solid #E0E0E0;
}

/* 分隔线 */
.divider {
  height: 1px;
  background-color: #E0E0E0;
  margin: 16px 0;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  color: #9E9E9E;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 16px;
  margin-bottom: 12px;
}

/* 标题样式 */
.title-large {
  font-size: 20px;
  font-weight: 600;
  color: #212121;
  line-height: 28px;
}

.title-medium {
  font-size: 18px;
  font-weight: 600;
  color: #212121;
  line-height: 24px;
}

/* 正文样式 */
.text-body {
  font-size: 16px;
  color: #212121;
  line-height: 22px;
}

.text-small {
  font-size: 14px;
  color: #757575;
  line-height: 20px;
}

.text-xs {
  font-size: 12px;
  color: #9E9E9E;
  line-height: 16px;
}

/* 间距 */
.mt-8 {
  margin-top: 8px;
}

.mt-16 {
  margin-top: 16px;
}

.mb-8 {
  margin-bottom: 8px;
}

.mb-16 {
  margin-bottom: 16px;
}

.p-16 {
  padding: 16px;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}