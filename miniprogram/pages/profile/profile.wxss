.container {
  background-color: #FAFAFA;
  min-height: 100vh;
  padding: 32rpx;
}

.profile-header {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fadeInDown 0.5s ease;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.avatar-container {
  display: inline-block;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #F0F0F0;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #F0F0F0;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 600;
  color: white;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 16rpx;
}

.edit-btn {
  background-color: #F5F5F5;
  color: #5B8FF9;
  border-radius: 32rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border: none;
  transition: all 0.2s ease;
}

.edit-btn-hover {
  background-color: #E8E8E8;
  transform: scale(0.96);
}

.stats-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.5s ease 0.1s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 600;
  color: #5B8FF9;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #757575;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #F0F0F0;
}

.info-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.5s ease 0.2s both;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #757575;
}

.info-value {
  font-size: 26rpx;
  color: #212121;
  font-weight: 500;
}

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 24rpx;
  text-align: center;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-static {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.avatar-preview-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.avatar-preview-text {
  font-size: 64rpx;
  font-weight: 600;
  color: white;
}

.avatar-tip {
  font-size: 24rpx;
  color: #8C8C8C;
}

.nickname-section {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.dialog-input {
  border: 2rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
  width: 100%;
}

.dialog-input:focus {
  border-color: #5B8FF9;
  background-color: #FFFFFF;
}

.dialog-buttons {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.dialog-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  border: none;
  transition: all 0.2s ease;
}

.dialog-btn:active {
  opacity: 0.8;
}

.cancel-btn {
  background-color: #F5F5F5;
  color: #757575;
}

.confirm-btn {
  background-color: #5B8FF9;
  color: white;
}
