/* index.wxss */
.container {
  padding: 32rpx;
  background-color: #FAFAFA;
  min-height: 100vh;
}

/* 欢迎栏 */
.welcome-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.welcome-text {
  flex: 1;
}

.greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.date-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.avatar-wrapper {
  margin-left: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
}

/* 班级卡片 */
.class-section {
  margin-bottom: 24px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #212121;
}

.add-class-btn {
  font-size: 14px;
  color: #3478F6;
}

.add-class-text {
  display: flex;
  align-items: center;
}

.class-scroll {
  white-space: nowrap;
  margin-bottom: 8px;
}

.class-cards {
  display: flex;
  gap: 12px;
  padding-bottom: 8px;
}

.class-card {
  width: 200px;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 120px;
}

.class-name {
  font-size: 16px;
  font-weight: 600;
  color: #212121;
  margin-bottom: 8px;
}

.class-info {
  font-size: 14px;
  color: #757575;
  margin-bottom: 8px;
}

.class-academic {
  font-size: 12px;
  color: #9E9E9E;
}

.add-card {
  border: 2px dashed #E0E0E0;
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.add-icon {
  font-size: 32px;
  color: #9E9E9E;
  margin-bottom: 8px;
}

.add-text {
  font-size: 14px;
  color: #9E9E9E;
}

/* 本周课程卡片 */
.week-schedule-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: none;
}

.add-btn {
  background-color: #5B8FF9;
  color: white;
}

.view-btn {
  background-color: #F5F5F5;
  color: #5B8FF9;
}

.btn-hover {
  opacity: 0.8;
}

.mini-schedule {
  margin-top: 24rpx;
}

.schedule-day {
  margin-bottom: 32rpx;
}

.schedule-day:last-child {
  margin-bottom: 0;
}

.day-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #5B8FF9;
}

.day-courses {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mini-course {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.mini-course-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

.mini-course-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.mini-course-time {
  display: block;
  font-size: 22rpx;
  opacity: 0.7;
  margin-bottom: 4rpx;
}

.mini-course-location {
  display: block;
  font-size: 20rpx;
  opacity: 0.6;
}

.no-course-tip {
  text-align: center;
  padding: 80rpx 0;
}

.tip-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.tip-text {
  display: block;
  font-size: 28rpx;
  color: #BFBFBF;
  margin-bottom: 24rpx;
}

.tip-btn {
  background-color: #5B8FF9;
  color: white;
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.get-user-info-btn {
  margin-top: 8px;
  font-size: 12px;
  padding: 4px 12px;
  background-color: #3478F6;
  color: white;
  border: none;
  border-radius: 4px;
}

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.dialog-content {
  background-color: white;
  border-radius: 20rpx;
  padding: 48rpx;
  width: 80%;
  max-width: 600rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 32rpx;
  text-align: center;
}

/* 表单样式 */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  border: 2rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
  width: 100%;
}

.form-input:focus {
  border-color: #5B8FF9;
  background-color: #FFFFFF;
}

.form-picker {
  border: 2rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
}

.picker-view {
  font-size: 28rpx;
  color: #262626;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
  cursor: pointer;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.avatar-preview-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.avatar-preview-text {
  font-size: 64rpx;
  font-weight: 600;
  color: white;
}

.avatar-tip {
  font-size: 24rpx;
  color: #8C8C8C;
}

.nickname-section {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.dialog-input {
  border: 2rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  background-color: #FAFAFA;
  width: 100%;
}

.dialog-input:focus {
  border-color: #5B8FF9;
  background-color: #FFFFFF;
}

.dialog-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  border: none;
  transition: all 0.2s ease;
}

.dialog-btn:active {
  opacity: 0.8;
}

.cancel-btn {
  background-color: #F5F5F5;
  color: #8C8C8C;
}

.confirm-btn {
  background-color: #5B8FF9;
  color: white;
}
