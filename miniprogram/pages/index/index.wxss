/* index.wxss */
.container {
  padding: 16px;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 教师信息 */
.teacher-info {
  display: flex;
  align-items: center;
  margin-bottom: 24px;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  margin-right: 16px;
}

.teacher-details {
  flex: 1;
}

.teacher-name {
  font-size: 18px;
  font-weight: 600;
  color: #212121;
  margin-bottom: 4px;
  display: block;
}

.teacher-subtitle {
  font-size: 14px;
  color: #757575;
}

/* 班级卡片 */
.class-section {
  margin-bottom: 24px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #212121;
}

.add-class-btn {
  font-size: 14px;
  color: #3478F6;
}

.add-class-text {
  display: flex;
  align-items: center;
}

.class-scroll {
  white-space: nowrap;
  margin-bottom: 8px;
}

.class-cards {
  display: flex;
  gap: 12px;
  padding-bottom: 8px;
}

.class-card {
  width: 200px;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 120px;
}

.class-name {
  font-size: 16px;
  font-weight: 600;
  color: #212121;
  margin-bottom: 8px;
}

.class-info {
  font-size: 14px;
  color: #757575;
  margin-bottom: 8px;
}

.class-academic {
  font-size: 12px;
  color: #9E9E9E;
}

.add-card {
  border: 2px dashed #E0E0E0;
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.add-icon {
  font-size: 32px;
  color: #9E9E9E;
  margin-bottom: 8px;
}

.add-text {
  font-size: 14px;
  color: #9E9E9E;
}

/* 快速操作 */
.quick-actions {
  margin-bottom: 24px;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  cursor: pointer;
}

.action-icon {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
  font-size: 14px;
  font-weight: 600;
  color: white;
}

.score-icon {
  background-color: #3478F6;
}

.comment-icon {
  background-color: #4CAF50;
}

.schedule-icon {
  background-color: #FF9800;
}

.attendance-icon {
  background-color: #F44336;
}

.notice-icon {
  background-color: #9C27B0;
}

.student-icon {
  background-color: #00BCD4;
}

.action-text {
  font-size: 14px;
  color: #212121;
  text-align: center;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .class-card {
    width: 180px;
  }
  
  .action-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 768px) {
  .action-grid {
    grid-template-columns: repeat(6, 1fr);
  }
}