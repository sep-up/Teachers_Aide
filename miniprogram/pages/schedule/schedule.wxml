<!-- pages/schedule/schedule.wxml -->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="title-section">
      <text class="title">课程表</text>
      <picker class="week-picker" bindchange="onWeekChange" value="{{currentWeek}}" range="{{weekOptions}}">
        <view class="picker-display">
          <text>{{weekOptions[currentWeek]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <button class="add-btn" bindtap="addCourse" hover-class="btn-hover" hover-stay-time="100">+ 添加</button>
  </view>
  
  <!-- 课程表 -->
  <view class="schedule-table">
    <!-- 表头 -->
    <view class="table-header">
      <view class="time-slot-header">时间</view>
      <view wx:for="{{days}}" wx:key="index" class="day-header">{{item}}</view>
    </view>
    
    <!-- 课程内容 -->
    <view wx:for="{{scheduleGrid}}" wx:key="rowIndex" wx:for-index="rowIndex" class="table-row">
      <view class="time-slot">{{timeSlots[rowIndex]}}</view>
      <view wx:for="{{item}}" wx:key="colIndex" wx:for-index="colIndex" wx:for-item="course" 
            class="course-cell" 
            data-day="{{colIndex + 1}}" 
            data-time="{{rowIndex + 1}}" 
            bindtap="onCourseClick">
        <view wx:if="{{course}}" 
              class="course-info" 
              style="background-color: {{course.color}};">
          <text class="course-name" style="color: {{course.textColor}};">{{course.courseName}}</text>
          <text wx:if="{{course.location}}" class="course-location">{{course.location}}</text>
        </view>
        <view wx:else class="empty-course"></view>
      </view>
    </view>
  </view>
  
  <!-- 课程详情对话框 -->
  <view wx:if="{{showDetailDialog}}" class="dialog-mask" catchtap="hideDetailDialog">
    <view class="dialog-content detail-dialog" catchtap="stopPropagation">
      <text class="dialog-title">课程详情</text>
      <view class="detail-item">
        <text class="detail-label">课程名称</text>
        <text class="detail-value">{{currentCourse.courseName}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">上课时间</text>
        <text class="detail-value">{{days[currentCourse.day - 1]}} {{timeSlots[currentCourse.timeSlot - 1]}}</text>
      </view>
      <view class="detail-item" wx:if="{{currentCourse.location}}">
        <text class="detail-label">上课地点</text>
        <text class="detail-value">{{currentCourse.location}}</text>
      </view>
      <view class="dialog-buttons">
        <button class="cancel-btn" bindtap="deleteCourse">删除</button>
        <button class="confirm-btn" bindtap="editCourse">编辑</button>
      </view>
    </view>
  </view>
  
  <!-- 添加/编辑课程对话框 -->
  <view wx:if="{{showAddDialog}}" class="dialog-mask" catchtap="hideAddDialog">
    <view class="dialog-content" catchtap="stopPropagation">
      <text class="dialog-title">{{editMode ? '编辑课程' : '添加课程'}}</text>
      <view class="form-item">
        <text class="form-label">星期</text>
        <picker class="form-picker" data-field="day" bindchange="handlePickerChange" value="{{formData.day}}" range="{{days}}">
          <view class="picker-view">{{days[formData.day]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">节次</text>
        <picker class="form-picker" data-field="timeSlot" bindchange="handlePickerChange" value="{{formData.timeSlot}}" range="{{timeSlots}}">
          <view class="picker-view">{{timeSlots[formData.timeSlot]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">课程名称</text>
        <input class="form-input" placeholder="请输入课程名称" data-field="courseName" bindinput="handleInput" value="{{formData.courseName}}" />
      </view>
      <view class="form-item">
        <text class="form-label">上课地点</text>
        <input class="form-input" placeholder="请输入上课地点" data-field="location" bindinput="handleInput" value="{{formData.location}}" />
      </view>
      <view class="dialog-buttons">
        <button class="cancel-btn" bindtap="hideAddDialog">取消</button>
        <button class="confirm-btn" bindtap="addCourseSubmit">{{editMode ? '更新' : '保存'}}</button>
      </view>
    </view>
  </view>
</view>