/* pages/notice/notice.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background-color: #3478F6;
  color: white;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
}

.notice-list {
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
}

.notice-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.notice-time {
  font-size: 20rpx;
  color: #999;
  margin-left: 20rpx;
}

.notice-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.notice-footer {
  display: flex;
  justify-content: flex-end;
}

.share-btn {
  background-color: #f0f0f0;
  color: #3478F6;
  border-radius: 40rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 24rpx;
}

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.dialog-content {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  width: 80%;
  max-width: 500rpx;
}

.dialog-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 5rpx;
  padding: 15rpx;
  font-size: 24rpx;
}

.form-textarea {
  border: 1rpx solid #e0e0e0;
  border-radius: 5rpx;
  padding: 15rpx;
  font-size: 24rpx;
  height: 200rpx;
  resize: none;
}

.dialog-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.cancel-btn {
  flex: 1;
  margin-right: 10rpx;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 5rpx;
}

.confirm-btn {
  flex: 1;
  margin-left: 10rpx;
  background-color: #3478F6;
  color: white;
  border-radius: 5rpx;
}